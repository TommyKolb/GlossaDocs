# shellcheck disable=SC2148,SC2034,SC2125,SC1017
# GlossaDocs backend - copy to .env for local non-Docker runs
# Used by: npm run dev (backend), migrate:up, start

NODE_ENV=development
# Global app mode switch: dev (local-friendly defaults) or prod (strict security checks).
APP_ENV=dev
# Identity provider used by app-hosted auth routes: keycloak (dev default) or cognito (prod default).
AUTH_PROVIDER=keycloak
API_PORT=4000
# CORS origin(s) allowed to call the backend.
# Use "*" only for local/dev. In production, use explicit origin(s), comma-separated if needed.
CORS_ALLOWED_ORIGINS=*

# PostgreSQL connection string (required for documents + settings)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/glossadocs
# Optional: PEM path for Amazon RDS TLS (defaults to backend/certs/rds-global-bundle.pem when present).
# RDS_CA_BUNDLE_PATH=
# Dev-only: allow TLS without verifying the server cert if the CA bundle file is missing (never use in prod).
# DATABASE_TLS_INSECURE=false

# Keycloak OIDC (required for JWT verification)
OIDC_ISSUER_URL=http://localhost:8080/realms/glossadocs
OIDC_AUDIENCE=glossadocs-api
# Optional: defaults to OIDC_ISSUER_URL/protocol/openid-connect/certs
# OIDC_JWKS_URL=http://localhost:8080/realms/glossadocs/protocol/openid-connect/certs
# In Cognito mode, when omitted this defaults to OIDC_ISSUER_URL/.well-known/jwks.json.

# Keycloak token endpoint and client (required for app-hosted login)
KEYCLOAK_TOKEN_URL=http://localhost:8080/realms/glossadocs/protocol/openid-connect/token
KEYCLOAK_CLIENT_ID=glossadocs-api
# Optional for confidential clients
# KEYCLOAK_CLIENT_SECRET=

# Keycloak Admin API (required for app-hosted signup + password reset)
# In Docker, KEYCLOAK_ADMIN_URL should be http://keycloak:8080
KEYCLOAK_ADMIN_URL=http://localhost:8080
KEYCLOAK_REALM=glossadocs
KEYCLOAK_ADMIN_USERNAME="admin"
KEYCLOAK_ADMIN_PASSWORD="admin"

# Cognito auth configuration (required when AUTH_PROVIDER=cognito).
# OIDC_ISSUER_URL and OIDC_AUDIENCE are auto-derived from these values when omitted.
# COGNITO_REGION=us-east-1
# COGNITO_USER_POOL_ID=us-east-1_example
# COGNITO_CLIENT_ID=exampleclientid
# Optional for confidential app clients:
# COGNITO_CLIENT_SECRET=
# Optional Cognito Hosted UI domain for /auth/public (e.g., https://myapp.auth.us-east-1.amazoncognito.com)
# COGNITO_PUBLIC_DOMAIN=
# Optional explicit values for GET /auth/public payload. In Cognito mode these can be inferred,
# but setting them helps keep frontend callback wiring explicit in production.
# OIDC_PUBLIC_ISSUER_URL=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_example
# OIDC_PUBLIC_CLIENT_ID=exampleclientid
# OIDC_PUBLIC_REDIRECT_URI=https://main.<amplify-domain>/auth/callback

# Backend-managed auth session cookie
AUTH_SESSION_COOKIE_NAME=glossadocs_session
AUTH_SESSION_TTL_SECONDS=3600
# Set true in production HTTPS environments
AUTH_SESSION_SECURE_COOKIE=false
# Per-IP auth rate limits (window in ms, max attempts in that window)
# AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=60000
# AUTH_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=20
# AUTH_PASSWORD_RESET_RATE_LIMIT_WINDOW_MS=60000
# AUTH_PASSWORD_RESET_RATE_LIMIT_MAX_ATTEMPTS=20
# Session store backend: memory (local/dev) or redis (recommended for production)
AUTH_SESSION_STORE=memory
# Required when AUTH_SESSION_STORE=redis
# REDIS_URL=redis://localhost:6379
AUTH_REDIS_KEY_PREFIX=glossadocs:session:

# Optional: base64-encoded 32-byte key for encrypting document title/content at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# DOCUMENT_ENCRYPTION_KEY=

# Max JSON body size in bytes (default 15 MiB). Increase if saving very large documents with inline images.
# API_BODY_LIMIT_BYTES=15728640
