# shellcheck disable=SC2148,SC2034,SC2125,SC1017
# GlossaDocs frontend (root) â€“ copy to `.env` for local non-Docker runs.
# This file is committed; `.env` and `.env.local` are gitignored (see `.gitignore`).
#
# Used by:
#   - `npm run dev` / Vite: variables prefixed with VITE_
#   - `npm run test:deployed`: PROD_* and E2E_* (loaded via dotenv in playwright.deployed.config.ts)

# Backend API base URL (browser will call this)
VITE_API_BASE_URL=http://localhost:4000

# --- Optional: deployed integration tests (`npm run test:deployed`) ---
# PROD_API_BASE_URL=https://YOUR_API.execute-api.REGION.amazonaws.com/prod
# PROD_FRONTEND_URL=https://main.YOUR_APP.amplifyapp.com
# E2E_PROD_EMAIL=e2e-user@example.com
# E2E_PROD_PASSWORD=use-a-dedicated-test-account
