{
  "name": "glossadocs-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env -- tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "dotenv -e .env -- node dist/server.js",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate:up": "dotenv -e .env -- node-pg-migrate -m migrations up",
    "migrate:down": "dotenv -e .env -- node-pg-migrate -m migrations down",
    "migrate:create": "dotenv -e .env -- node-pg-migrate -m migrations create"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv-cli": "^10.0.0",
    "node-pg-migrate": "^8.0.4",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@fastify/aws-lambda": "^6.4.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "fastify": "^5.8.2",
    "ioredis": "^5.10.1",
    "jose": "^6.2.0",
    "pg": "^8.20.0",
    "sanitize-html": "^2.17.1",
    "zod": "^4.3.6"
  }
}
