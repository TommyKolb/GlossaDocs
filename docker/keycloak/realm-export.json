{
  "realm": "glossadocs",
  "enabled": true,
  "displayName": "GlossaDocs",
  "registrationAllowed": false,
  "users": [
    {
      "username": "devuser",
      "enabled": true,
      "emailVerified": true,
      "email": "devuser@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "devpass",
          "temporary": false
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "glossadocs-api",
      "name": "GlossaDocs API",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:5173"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "profile",
        "email",
        "roles"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ]
}

